# development = SQLite lokaal | production = PostgreSQL op de server
APP_ENV=development

# Alleen nodig in development (SQLite)
DATABASE_URL="file:./dev.db"

# Alleen nodig in production (PostgreSQL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=bugtracker
# DB_USER=bugtracker
# DB_PASSWORD=change-me
# DB_SSL=false

SESSION_SECRET=
ADMIN_EMAIL=
# Minimaal 12 tekens; gebruik aanhalingstekens bij speciale tekens
ADMIN_PASSWORD="change-me-admin-password-12chars"
PORT=4000
FRONTEND_URL=http://localhost:5173
PUBLIC_URL=http://localhost:4000
COOKIE_SECURE=false

# Mailgun (vereist voor klantuitnodigingen, wachtwoord-reset en e-mailnotificaties)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAIL_FROM="Bugtracker <noreply@jouwdomein.nl>"
MAILGUN_API_BASE=https://api.eu.mailgun.net
